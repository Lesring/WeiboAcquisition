# 复制为 .env 后填写：copy .env.example .env

# 微博 UID（数字）
WEIBO_UID=5635286888

# weibo.com / m.weibo.cn 请求 Cookie（一行，勿加引号除非值内必需）
WEIBO_COOKIE=

# PC 端 ajax（weibopc.py）：浏览器里 weibo.com 的 XSRF-TOKEN
WEIBO_XSRF_PC=

# m 站（weibom_pre_20170301.py）请求头 X-XSRF-TOKEN，可与 Cookie 里 XSRF-TOKEN 一致；不填则尝试用 WEIBO_XSRF_PC
WEIBO_XSRF_M=

# 可选：自定义 User-Agent
# WEIBO_UA=Mozilla/5.0 ...

# ---- 输出 / 输入路径 ----
# 移动端时间线 jsonl（WeiboVault.py）
# WEIBO_JSONL_MOBILE=weibovault_5635286888.jsonl

# PC 时间线 jsonl（weibopc.py 写入；downloadweibopc.py 读取）
WEIBO_JSONL_PC=weibovault_5635286888_pc.jsonl

# 较早微博 m 站 jsonl（weibom_pre_20170301.py / download_weibovault_incremental.py）
WEIBO_JSONL_M_PRE=weibovault_5635286888_m_pre20170301.jsonl

# 媒体下载根目录（downloadweibopc.py、download_weibovault_incremental.py）
WEIBO_DOWNLOAD_DIR=D:\lww

# 相册图片输出目录（download_album_all_images.py）
WEIBO_ALBUM_OUT_DIR=D:\weibo_album_images

# 相册接口 containerid（相册页抓包可得）
WEIBO_ALBUM_CONTAINER_ID=1078035635286888_38555701961531260000005635286888_-_albumeach

# 相册分页（可选）
# WEIBO_ALBUM_START_PAGE=1
# WEIBO_ALBUM_MAX_PAGES=5000
# WEIBO_ALBUM_PAGE_COUNT=24

# 按日期汇总媒体（collect_media_by_date.py）
WEIBO_COLLECT_SRC=D:\lww
WEIBO_COLLECT_DST_IMAGES=D:\lww_collect\images
WEIBO_COLLECT_DST_VIDEOS=D:\lww_collect\videos

# 抓取停止：早于该日期则停（weibom_pre_20170301.py，YYYY-MM-DD）
WEIBO_STOP_BEFORE=2017-03-01

# HTTP 超时秒数（可选）
# WEIBO_HTTP_CONNECT_TIMEOUT=10
# WEIBO_HTTP_READ_TIMEOUT=60

# 部分脚本间隔（可选，不填则用脚本默认值）
# WEIBO_SLEEP_SEC=0.8
