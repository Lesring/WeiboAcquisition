# 复制为 .env：copy .env.example .env

# ---- 爬取目标（必填其一；与命令行 -t 等价）----
# 用户主页链接（须能解析出数字 UID），例如：
# WEIBO_TARGET=https://weibo.com/u/1234567890
# 或纯数字：
# WEIBO_TARGET=1234567890
# 也可用 WEIBO_UID=1234567890（效果相同，都会解析为 UID）

# ---- 数据根目录 ----
# 每个用户输出到：WEIBO_DATA_ROOT/<UID>/...
# WEIBO_DATA_ROOT=./data

# ---- 登录态（爬 PC / 相册 / 部分下载通常需要）----
# Cookie 一整行；若含 # 等字符请加双引号：WEIBO_COOKIE="SUB=...; ..."
WEIBO_COOKIE=

# PC 端 ajax（crawl-pc）：浏览器 weibo.com 的 XSRF-TOKEN
WEIBO_XSRF_PC=

# m 站 crawl-m-pre 请求头 X-XSRF-TOKEN；不填则尝试用 WEIBO_XSRF_PC
WEIBO_XSRF_M=

# ---- 可选：自定义 UA ----
# WEIBO_UA=Mozilla/5.0 ...

# ---- 路径覆盖（一般不必写：run_weibo 会按 <UID> 自动填）----
# WEIBO_JSONL_MOBILE=
# WEIBO_JSONL_PC=
# WEIBO_JSONL_M_PRE=
# WEIBO_DOWNLOAD_DIR=
# WEIBO_ALBUM_OUT_DIR=
# WEIBO_COLLECT_SRC=
# WEIBO_COLLECT_DST_IMAGES=
# WEIBO_COLLECT_DST_VIDEOS=

# ---- 相册（album 子命令必填其一）----
# 从 m.weibo.cn 相册接口请求中复制 containerid
WEIBO_ALBUM_CONTAINER_ID=

# WEIBO_ALBUM_START_PAGE=1
# WEIBO_ALBUM_MAX_PAGES=5000
# WEIBO_ALBUM_PAGE_COUNT=24

# ---- crawl-m-pre：翻到早于该日期则停（YYYY-MM-DD）----
WEIBO_STOP_BEFORE=2017-03-01

# ---- 可选性能 ----
# WEIBO_HTTP_CONNECT_TIMEOUT=10
# WEIBO_HTTP_READ_TIMEOUT=60
# WEIBO_SLEEP_SEC=0.8
# WEIBO_M_MAX_PAGES=10000
